# Django
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gzeams

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ALL_ORIGINS=True

# Health metrics endpoint access
HEALTH_METRICS_ALLOWLIST=127.0.0.1,::1
HEALTH_METRICS_TRUST_X_FORWARDED_FOR=False
HEALTH_METRICS_TOKEN=replace-with-strong-random-token
