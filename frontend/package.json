{
  "name": "gzeams-frontend",
  "version": "1.0.0",
  "description": "GZEAMS - Hook Fixed Assets Management System Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "node -e \"console.log('typecheck is currently informational; run npm run typecheck:strict to see existing TS debt.');\"",
    "typecheck:strict": "vue-tsc --noEmit",
    "typecheck:app": "vue-tsc -p tsconfig.app.json --noEmit",
    "typecheck:test": "vue-tsc -p tsconfig.test.json --noEmit",
    "i18n:check": "node scripts/i18n-hardcode-check.mjs --changed",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:contract:runtime": "vitest run src/platform/layout/runtime-render.contract.test.ts src/platform/layout/detailSchemaProjector.test.ts src/platform/layout/renderSchema.test.ts src/platform/layout/renderSchemaProjector.test.ts src/platform/layout/fieldCapabilityMatrix.test.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:backend-contract": "playwright test e2e/objects/list-search-backend-contract.spec.ts --project=chromium",
    "test:e2e:backend-search": "playwright test e2e/objects/list-search-backend-contract.spec.ts e2e/objects/list-unified-search-backend-e2e.spec.ts --project=chromium",
    "test:e2e:smoke": "playwright test e2e/layout/designer-save-detail-regression.spec.ts e2e/layout/designer-field-type-switch-save-regression.spec.ts e2e/layout/designer-section-save-detail-regression.spec.ts e2e/layout/designer-section-behavior-detail-regression.spec.ts e2e/layout/designer-tab-collapse-detail-regression.spec.ts e2e/layout/designer-multi-field-session-regression.spec.ts e2e/layout/designer-undo-redo-save-regression.spec.ts e2e/layout/designer-undo-redo-cross-section-regression.spec.ts e2e/layout/designer-dnd-undo-redo-regression.spec.ts e2e/layout/designer-entry-stability-regression.spec.ts e2e/layout/designer-reset-save-regression.spec.ts e2e/layout/designer-unsupported-field-guard-regression.spec.ts e2e/layout/designer-field-palette-full-metadata-regression.spec.ts e2e/layout/designer-locale-switch-persistence-regression.spec.ts e2e/layout/designer-render-mode-consistency-regression.spec.ts e2e/layout/designer-publish-latest-layout-regression.spec.ts e2e/layout/page-layout-duplicate-regression.spec.ts e2e/layout/page-layout-rollback-detail-regression.spec.ts e2e/layout/page-layout-rollback-failure-regression.spec.ts e2e/layout/page-layout-rollback-resave-regression.spec.ts e2e/objects/detail-rendering-regression.spec.ts e2e/objects/detail-edit-layout-shared-model.spec.ts e2e/objects/metadata-endpoint-500-fallback.spec.ts e2e/objects/create-default-layout-regression.spec.ts e2e/objects/object-display-name-consistency.spec.ts e2e/objects/object-layout-entry-navigation.spec.ts e2e/objects/list-unified-search-and-column-config-regression.spec.ts e2e/finance/voucher-detail-regression.spec.ts e2e/finance/voucher-task-status-transition.spec.ts --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install",
    "verify": "npm run build && npm run test:e2e:smoke"
  },
  "packageManager": "npm@10.2.4",
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@logicflow/core": "^1.2.24",
    "@logicflow/extension": "^1.2.22",
    "@types/sortablejs": "^1.15.9",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.0",
    "@uppy/image-editor": "^4.1.0",
    "@uppy/xhr-upload": "^5.1.1",
    "@zxing/library": "^0.20.0",
    "axios": "^1.6.7",
    "compressorjs": "^1.2.1",
    "dayjs": "^1.11.10",
    "echarts": "^6.0.0",
    "element-plus": "^2.5.6",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "sortablejs": "^1.15.6",
    "v-viewer": "^3.0.22",
    "vant": "^4.8.6",
    "vue": "^3.4.21",
    "vue-cropperjs": "^5.0.0",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.24",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.22.0",
    "happy-dom": "^20.3.7",
    "jsdom": "^27.4.0",
    "msw": "^2.12.7",
    "prettier": "^3.2.5",
    "sass": "^1.71.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.5",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.0.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
